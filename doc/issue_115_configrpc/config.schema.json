{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Bitcoin Config Key-Value Map",
  "type": "object",
  "additionalProperties": {
    "oneOf": [
      { "type": "boolean" },
      { "type": "integer" },
      { "type": "number" },
      { "type": "string" }
    ]
  },
  "examples": [
    {
      "blockmaxweight": 1500000,
      "mempoolminfee": "0.00001",
      "listen": true
    }
  ]
}